PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Local Postgres example:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bud
# Hosted providers such as Render often require SSL:
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
PG_POOL_MAX=10

# Optional Phase 2 daemon gRPC control listener. WebSocket /ws remains enabled.
GRPC_CONTROL_ENABLED=false
GRPC_CONTROL_HOST=127.0.0.1
GRPC_CONTROL_PORT=50051
GRPC_CONTROL_MAX_MESSAGE_BYTES=4194304
# Daemon carrier preference: websocket_baseline, h2_preferred, or quic_preferred.
DAEMON_TRANSPORT_POLICY=websocket_baseline
# Public origin for one-command Bud installer links generated by the service.
DAEMON_INSTALLER_BASE_URL=https://get.bud.dev

# Local iOS auth uses the web origin as the public app/auth origin.
APP_BASE_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173
API_AUDIENCE=http://localhost:5173/api
# Prototype deployed environments should usually collapse these to one public origin:
# APP_BASE_URL=https://bud.example.com
# BETTER_AUTH_URL=https://bud.example.com
# API_AUDIENCE=https://bud.example.com/api
# OAUTH_TRUSTED_CLIENT_IDS=bud-ios-staging
BETTER_AUTH_SECRET=bud-dev-better-auth-secret-change-me-please
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Hosted web-view proxy. Local defaults work without these; staging/prod should
# set PROXY_EDGE_SECRET when Cloudflare forwards *.bud.show to the service.
# PROXY_PUBLIC_SCHEME=https
# PROXY_BASE_DOMAIN=bud.show
# PROXY_PUBLIC_PORT=
# PROXY_GATEWAY_ENABLED=true
# PROXY_VIEWER_COOKIE_NAME=__Host-bud_proxy_viewer
# PROXY_EDGE_SECRET=

# Optional first-party cache/hardening list. The provisioning script also sets
# skip_consent on the stored local client row.
OAUTH_TRUSTED_CLIENT_IDS=bud-ios-dev-local

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# APNs push notifications. Leave APNS_KEY_ID and APNS_TEAM_ID blank to keep
# the push worker disabled locally; APNS_KEY_FILE is only read when both are set.
APNS_KEY_ID=
APNS_TEAM_ID=
# Preferred for hosting providers with secret-file support. Points at the .p8 file path.
APNS_KEY_FILE=
# Fallback for inline secret envs. Escaped newlines are supported, e.g.
# "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----".
APNS_PRIVATE_KEY=
# Normal delivery uses the registered endpoint app_id as apns-topic. This is
# only a fallback for malformed/legacy endpoint rows without app_id.
APNS_DEFAULT_TOPIC=
APNS_ALLOWED_TOPICS=chat.bud.app,chat.bud.app.staging

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional direct local-dev ds4 provider. Leave DS4_DIRECT_BASE_URL blank to disable.
# Use 127.0.0.1 or localhost; 127.0.0.0 will not reach the local ds4 listener.
DS4_DIRECT_BASE_URL=
DS4_DIRECT_MODEL=deepseek-v4-flash
DS4_DIRECT_CONTEXT_TOKENS=100000
DS4_DIRECT_MAX_OUTPUT_TOKENS=384000
# First-party model catalog default. See /api/models for available model/reasoning pairs.
DEFAULT_MODEL=gpt-5.5
AGENT_REASONING_EFFORT=low
# Local-only model context drift diagnostics. Writes under .bud-debug/ when enabled.
AGENT_CONTEXT_DRIFT_DEBUG=false
