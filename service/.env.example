PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Local Postgres example:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bud
# Hosted providers such as Render often require SSL:
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
PG_POOL_MAX=10

# Local iOS auth uses the web origin as the public app/auth origin.
APP_BASE_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:5173
API_AUDIENCE=http://localhost:5173/api
# Prototype deployed environments should usually collapse these to one public origin:
# APP_BASE_URL=https://bud.example.com
# BETTER_AUTH_URL=https://bud.example.com
# API_AUDIENCE=https://bud.example.com/api
# OAUTH_TRUSTED_CLIENT_IDS=bud-ios-staging
BETTER_AUTH_SECRET=bud-dev-better-auth-secret-change-me-please
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional first-party cache/hardening list. The provisioning script also sets
# skip_consent on the stored local client row.
OAUTH_TRUSTED_CLIENT_IDS=bud-ios-dev-local

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=claude-opus-4-5
