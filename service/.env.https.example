PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info

# Optional local HTTPS parity profile.
# Copy this file to service/.env, then fill secrets as needed. The default
# service/.env.example remains the recommended no-Caddy HTTP quickstart.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/bud
PG_POOL_MAX=10

GRPC_CONTROL_ENABLED=false
GRPC_CONTROL_HOST=127.0.0.1
GRPC_CONTROL_PORT=50051
GRPC_CONTROL_MAX_MESSAGE_BYTES=4194304
DAEMON_TRANSPORT_POLICY=websocket_baseline

# Caddy fronts the app/auth/API bundle at https://localhost:3443. The service
# itself still listens on http://127.0.0.1:3000. Use literal localhost here
# because Google OAuth accepts localhost but rejects arbitrary .localhost
# hostnames as authorized origins/redirect URIs.
APP_BASE_URL=https://localhost:3443
BETTER_AUTH_URL=https://localhost:3443
API_AUDIENCE=https://localhost:3443/api
BETTER_AUTH_SECRET=bud-dev-better-auth-secret-change-me-please
BETTER_AUTH_TRUSTED_ORIGINS=https://localhost:3443,http://localhost:5173,http://localhost:3000
OAUTH_TRUSTED_CLIENT_IDS=bud-ios-dev-local

# Local HTTPS web-proxy endpoint hosts. The .test base domain requires local
# wildcard DNS such as dnsmasq: *.bud-show.test -> 127.0.0.1.
# PROXY_PUBLIC_PORT is explicit because the Caddy profile uses an unprivileged
# local HTTPS port.
PROXY_PUBLIC_SCHEME=https
PROXY_BASE_DOMAIN=bud-show.test
PROXY_PUBLIC_PORT=3443
PROXY_VIEWER_COOKIE_NAME=__Host-bud_proxy_viewer

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_FILE=
APNS_PRIVATE_KEY=
APNS_DEFAULT_TOPIC=
APNS_ALLOWED_TOPICS=chat.bud.app,chat.bud.app.staging

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=gpt-5.5
AGENT_REASONING_EFFORT=low
