{
  "name": "@bud/service",
  "version": "0.0.1",
  "private": true,
  "description": "Bud backend (REST + SSE + WS gateway + agent).",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "tsx src/runtime/session-manager.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "tsx src/scripts/db-push.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/scripts/seed.ts",
    "oauth:provision:ios-local": "tsx src/scripts/provision-ios-local-oauth-client.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@better-auth/oauth-provider": "^1.5.5",
    "@fastify/websocket": "^10.0.1",
    "better-auth": "^1.5.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.7",
    "fastify": "^4.28.1",
    "fastify-sse-v2": "^2.2.1",
    "openai": "^6.8.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "ulid": "^2.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.15.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
