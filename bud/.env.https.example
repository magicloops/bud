# Optional local HTTPS parity profile.
# Copy this file to bud/.env when testing through Caddy. The default
# bud/.env.example remains the recommended no-Caddy HTTP quickstart.

BUD_SERVER_URL=wss://localhost:3443/ws
BUD_DEVICE_NAME=bud-dev
BUD_TERMINAL_ENABLED=true

# Optional local state overrides:
# BUD_DEFAULT_CWD=$HOME
# BUD_IDENTITY_FILE=$HOME/.bud/identity.json
# BUD_TERMINAL_BASE_DIR=$HOME/.bud
# BUD_DEBUG=false
