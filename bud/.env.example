# Default local HTTP control path.
# Bud does not load this file automatically; run:
# set -a; source .env; set +a

BUD_SERVER_URL=ws://localhost:3000/ws
BUD_DEVICE_NAME=bud-dev
BUD_TERMINAL_ENABLED=true
# BUD_CLAIM_ID=

# Optional Bud-local ds4 forwarding. The daemon must already be running beside
# a ds4 server; Bud only probes and forwards the allowlisted API path.
# BUD_LOCAL_LLM_DS4_URL=http://127.0.0.1:8000
# BUD_LOCAL_LLM_DS4_CONTEXT_TOKENS=100000
# BUD_LOCAL_LLM_DS4_MAX_OUTPUT_TOKENS=128000

# Optional local state overrides:
# BUD_BASE_DIR=$HOME/.bud
# BUD_LOCAL=false
# BUD_DEFAULT_CWD=$HOME
# BUD_IDENTITY_FILE=$HOME/.bud/identity.json
# BUD_TERMINAL_BASE_DIR=$HOME/.bud
# BUD_DEBUG=false
