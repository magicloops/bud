# Recommended local browser/workbench setup: send API and SSE traffic directly
# to the Fastify service on localhost:3000 so multi-tab thread views do not
# compete through the Vite-origin connection pool.
VITE_API_BASE_URL=http://localhost:3000

# Optional: keep the dev proxy target aligned for auth/discovery flows or any
# targeted same-origin checks you still want to run through localhost:5173.
VITE_API_PROXY_TARGET=http://localhost:3000

# Prototype deployed environments should usually leave VITE_API_BASE_URL unset
# and keep browser auth/API traffic same-origin via path routing.

# Optional allowlist for hosted mobile-claim callbacks. Values are public callback
# prefixes, not secrets. Comma separate multiple entries when needed.
# VITE_MOBILE_CLAIM_CALLBACK_ALLOWED_PREFIXES=chat.bud.app://claim/,https://app.bud.dev/claim/

VITE_ROUTER_DEVTOOLS=false
