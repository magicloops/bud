# Optional local HTTPS parity profile.
# Copy this file to web/.env when testing through Caddy. The default
# web/.env.example remains the recommended no-Caddy HTTP quickstart.

# Leave VITE_API_BASE_URL unset so browser API/SSE calls stay same-origin at
# https://localhost:3443 and Caddy routes /api/* to the service.
# VITE_API_BASE_URL=

# Optional direct-Vite fallback only. The HTTPS profile's main browser path uses
# Caddy, so this is not needed when opening https://localhost:3443.
# VITE_API_PROXY_TARGET=http://localhost:3000

VITE_ROUTER_DEVTOOLS=false
